# ============================================================================
# DatumOS — environment for DURABLE cloud hosting (Vercel + managed Postgres)
# ============================================================================
# Local dev uses SQLite (.env -> file:./dev.db) with zero setup.
# For a permanent public deployment on a serverless host (no persistent disk),
# switch to Postgres by:
#   1. cp prisma/schema.postgres.prisma prisma/schema.prisma
#   2. set the DATABASE_URL below to your Neon / Supabase connection string
#   3. npx prisma migrate deploy   (creates tables)
#   4. npm run db:seed             (loads the same demo data)
#
# Neon example:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/datumos?sslmode=require"
#
# Supabase example (use the "Connection pooling" / port 6543 string for serverless):
# DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

DATABASE_URL="postgresql://user:password@host:5432/datumos?sslmode=require"

// ─── v28: GoHighLevel-inspired modules ────────────────────────────────────────

model Conversation {
  id              String    @id @default(cuid())
  contactName     String
  contactEmail    String?
  contactCompany  String?
  lastMessage     String?
  lastMessageAt   DateTime  @default(now())
  unreadCount     Int       @default(0)
  status          String    @default("OPEN")   // OPEN | CLOSED | SNOOZED
  channel         String    @default("EMAIL")  // EMAIL | SMS | CHAT | INTERNAL
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  messages        ConvMessage[]
}

model ConvMessage {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  content         String
  type            String       @default("EMAIL")    // EMAIL | SMS | NOTE | INTERNAL
  direction       String       @default("INBOUND")  // INBOUND | OUTBOUND
  senderName      String?
  createdAt       DateTime     @default(now())
}

model Campaign {
  id              String    @id @default(cuid())
  name            String
  subject         String?
  body            String?
  status          String    @default("DRAFT")  // DRAFT | ACTIVE | COMPLETED | PAUSED
  targetAudience  String?
  sentCount       Int       @default(0)
  openCount       Int       @default(0)
  clickCount      Int       @default(0)
  replyCount      Int       @default(0)
  scheduledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model DatumForm {
  id              String          @id @default(cuid())
  name            String
  description     String?
  fields          String?         // JSON array of field definitions
  status          String          @default("ACTIVE")  // ACTIVE | DRAFT | ARCHIVED
  submissionCount Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  submissions     FormSubmission[]
}

model FormSubmission {
  id          String     @id @default(cuid())
  formId      String
  form        DatumForm  @relation(fields: [formId], references: [id], onDelete: Cascade)
  data        String?    // JSON of submitted field values
  submittedAt DateTime   @default(now())
  ipAddress   String?
}

model Appointment {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("CLIENT_MEETING")  // CLIENT_MEETING | BIM_COORDINATION | SITE_VISIT | INTERNAL_REVIEW | TRAINING
  startTime   DateTime
  endTime     DateTime
  attendees   String?   // JSON array of names/emails
  location    String?
  status      String    @default("CONFIRMED")  // CONFIRMED | PENDING | CANCELLED | COMPLETED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Automation {
  id              String    @id @default(cuid())
  name            String
  description     String?
  trigger         String    // e.g. "New Lead Created", "Invoice Overdue"
  actions         String?   // JSON array of action steps
  status          String    @default("ACTIVE")  // ACTIVE | PAUSED | DRAFT
  executionCount  Int       @default(0)
  lastExecutedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Review {
  id          String    @id @default(cuid())
  clientName  String
  projectName String?
  rating      Int       @default(5)  // 1-5
  content     String?
  status      String    @default("PUBLISHED")  // PUBLISHED | PENDING | HIDDEN
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ChatMessage {
  id              String       @id @default(cuid())
  conversationId  String
  content         String
  type            String       @default("EMAIL")    // EMAIL | SMS | NOTE | INTERNAL
  direction       String       @default("INBOUND")  // INBOUND | OUTBOUND

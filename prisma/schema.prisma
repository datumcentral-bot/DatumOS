generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  password             String?
  role                 String                @default("MEMBER")
  title                String?
  division             String?
  avatarHue            String?
  capacityHrs          Float                 @default(40)
  active               Boolean               @default(true)
  createdAt            DateTime              @default(now())
  actionItems          ActionItem[]          @relation("ActionItemAssignee")
  activityLogs         ActivityLog[]
  comments             Comment[]
  sentMessages         InternalMessage[]     @relation("MessageAuthor")
  meetingParticipants  MeetingParticipant[]
  modelProductions     ModelProduction[]
  outreach             OutreachActivity[]
  assignments          ProjectAssignment[]
  qaSignoffs           QaSignoff[]
  resourceAllocations  ResourceAllocation[]
  raisedRfis           Rfi[]                 @relation("RfiRaisedBy")
  savedViews           SavedView[]
  starredItems         StarredItem[]
  subcontractorMembers SubcontractorMember[]
  tasks                Task[]                @relation("TaskAssignee")
  timeEntries          TimeEntry[]
  timesheets           TimesheetEntry[]
  warRoomIncidents     WarRoomIncident[]
}

model ClientUser {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Client {
  id               String              @id @default(cuid())
  companyName      String
  industry         String?
  country          String              @default("")
  city             String?
  address          String?
  contactName      String              @default("")
  contactEmail     String              @default("")
  contactPhone     String?
  website          String?
  timezone         String?
  logoHue          String?
  notes            String?
  status           String              @default("ACTIVE")
  tier             String              @default("TIER2")
  leadMember       String?
  repTeam          String?
  priority         String              @default("MEDIUM")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  assessments      ClientAssessment[]
  contacts         ClientContact[]
  documents        ClientDocument[]
  requirements     ClientRequirement[]
  portalUsers      ClientUser[]
  financialEntries FinancialEntry[]
  invoices         Invoice[]
  leads            Lead[]
  projects         Project[]
}

model ClientContact {
  id        String  @id @default(cuid())
  clientId  String
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean @default(false)
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientRequirement {
  id          String   @id @default(cuid())
  clientId    String
  title       String
  description String?
  category    String   @default("GENERAL")
  priority    String   @default("MEDIUM")
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientAssessment {
  id         String   @id @default(cuid())
  clientId   String
  title      String
  criteria   String?
  score      Float    @default(0)
  maxScore   Float    @default(10)
  notes      String?
  assessedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientDocument {
  id         String   @id @default(cuid())
  clientId   String
  name       String
  fileType   String?
  fileSize   Int?
  url        String?
  uploadedAt DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Division {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  description      String?
  colorHex         String            @default("#234b84")
  isFlagship       Boolean           @default(false)
  projectDivisions ProjectDivision[]
}

model Project {
  id                       String                    @id @default(cuid())
  name                     String
  code                     String?
  clientId                 String?
  description              String?
  status                   String                    @default("ACTIVE")
  phase                    String?
  startDate                DateTime?
  endDate                  DateTime?
  budget                   Float?
  contractValue            Float?
  bimLevel                 String?
  isoStage                 String?
  location                 String?
  country                  String?
  healthScore              Int                       @default(75)
  health                   String?
  healthNote               String?
  stage                    String?
  coverHue                 String?
  progressPct              Int                       @default(0)
  actualHrs                Float?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  airs                     Air[]
  approvals                Approval[]
  attachments              Attachment[]              @relation("ProjectAttachments")
  beps                     Bep[]
  bimCoordSchedules        BimCoordSchedule[]
  bimDeliveryMilestones    BimDeliveryMilestone[]
  bimScopeMatrix           BimScopeMatrix[]
  bimVerifyChecks          BimVerifyCheck[]
  cdeDocs                  CdeDocument[]
  clashes                  Clash[]
  clashDetections          ClashDetection[]
  messages                 ClientMessage[]
  comments                 Comment[]                 @relation("ProjectComments")
  deliverables             Deliverable[]
  deliverySchedules        DeliverySchedule[]
  documents                Document[]
  eirs                     Eir[]
  expenses                 Expense[]
  financialEntries         FinancialEntry[]
  ganttTasks               GanttTask[]
  invoices                 Invoice[]
  isoComplianceItems       IsoComplianceItem[]
  lodSpecs                 LodSpec[]
  meetings                 Meeting[]
  midps                    Midp[]
  milestones               Milestone[]
  modelProductions         ModelProduction[]
  namingConventions        NamingConvention[]
  client                   Client?                   @relation(fields: [clientId], references: [id])
  assignments              ProjectAssignment[]
  divisions                ProjectDivision[]
  projectFiles             ProjectFile[]
  folders                  ProjectFolder[]
  tags                     ProjectTag[]
  qaSignoffs               QaSignoff[]
  resourceAllocations      ResourceAllocation[]
  responsibilityMatrix     ResponsibilityMatrix[]
  rfis                     Rfi[]
  risks                    Risk[]
  scheduleItems            ScheduleItem[]
  scopes                   ScopeOfWork[]
  statusReports            StatusReport[]
  subcontractorAssignments SubcontractorAssignment[]
  tasks                    Task[]
  tidps                    Tidp[]
  timesheets               TimesheetEntry[]
  warRoomIncidents         WarRoomIncident[]
}

model ProjectAssignment {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String?
  isLead    Boolean @default(false)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])
}

model ProjectDivision {
  id         String   @id @default(cuid())
  projectId  String
  divisionId String
  division   Division @relation(fields: [divisionId], references: [id])
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  fileType   String?
  fileSize   Int?
  url        String?
  version    String   @default("v001")
  status     String   @default("WIP")
  discipline String?
  uploadedAt DateTime @default(now())
  uploadedBy String?
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Task {
  id            String              @id @default(cuid())
  title         String
  description   String?
  projectId     String?
  assigneeId    String?
  status        String              @default("TODO")
  priority      String              @default("MEDIUM")
  dueDate       DateTime?
  startDate     DateTime?
  estimatedHrs  Float?
  loggedHrs     Float               @default(0)
  actualHrs     Float?
  divisionCode  String?
  sopId         String?
  scopeId       String?
  cdeState      String?             @default("S0")
  qaRequired    Boolean?            @default(true)
  orderIndex    Int                 @default(0)
  parentId      String?
  tags          String?
  customFields  String?
  isTemplate    Boolean             @default(false)
  templateName  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  attachments   Attachment[]        @relation("TaskAttachments")
  comments      Comment[]           @relation("TaskComments")
  subtaskItems  SubtaskItem[]
  assignee      User?               @relation("TaskAssignee", fields: [assigneeId], references: [id])
  parent        Task?               @relation("SubTasks", fields: [parentId], references: [id])
  subtasks      Task[]              @relation("SubTasks")
  project       Project?            @relation(fields: [projectId], references: [id])
  scope         ScopeOfWork?        @relation(fields: [scopeId], references: [id])
  sop           Sop?                @relation(fields: [sopId], references: [id])
  checklist     TaskChecklistItem[]
  blockedByDeps TaskDependency[]    @relation("BlockedByTask")
  blockingDeps  TaskDependency[]    @relation("BlockingTask")
  timeEntries   TimeEntry[]
  timesheets    TimesheetEntry[]
}

model TaskDependency {
  id             String @id @default(cuid())
  blockingTaskId String
  blockedTaskId  String
  type           String @default("BLOCKS")
  blockedTask    Task   @relation("BlockedByTask", fields: [blockedTaskId], references: [id], onDelete: Cascade)
  blockingTask   Task   @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id          String    @id @default(cuid())
  taskId      String
  userId      String
  startedAt   DateTime
  stoppedAt   DateTime?
  durationMin Int?
  notes       String?
  createdAt   DateTime  @default(now())
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  authorId  String
  taskId    String?
  projectId String?
  meetingId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  project   Project? @relation("ProjectComments", fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?    @relation("TaskComments", fields: [taskId], references: [id], onDelete: Cascade)
}

model Attachment {
  id         String   @id @default(cuid())
  name       String
  fileType   String?
  fileSize   Int?
  url        String?
  taskId     String?
  projectId  String?
  uploadedAt DateTime @default(now())
  uploadedBy String?
  project    Project? @relation("ProjectAttachments", fields: [projectId], references: [id], onDelete: Cascade)
  task       Task?    @relation("TaskAttachments", fields: [taskId], references: [id], onDelete: Cascade)
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  colorHex String       @default("#4a7c59")
  projects ProjectTag[]
}

model ProjectTag {
  id        String  @id @default(cuid())
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
}

model SavedView {
  id        String   @id @default(cuid())
  userId    String
  name      String
  module    String
  filters   String?
  sortBy    String?
  viewType  String   @default("LIST")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StarredItem {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("PENDING")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Deliverable {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("PENDING")
  discipline  String?
  format      String?
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Bep {
  id           String   @id @default(cuid())
  projectId    String
  title        String
  version      String   @default("1.0")
  status       String   @default("DRAFT")
  projectInfo  String?
  objectives   String?
  standards    String?
  software     String?
  coordination String?
  qualityPlan  String?
  deliveryPlan String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Midp {
  id           String            @id @default(cuid())
  projectId    String
  title        String
  version      String            @default("1.0")
  status       String            @default("DRAFT")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverables MidpDeliverable[]
  tidps        Tidp[]
}

model MidpDeliverable {
  id          String    @id @default(cuid())
  midpId      String
  title       String
  discipline  String?
  format      String?
  lodLevel    String?
  dueDate     DateTime?
  status      String    @default("PENDING")
  responsible String?
  notes       String?
  createdAt   DateTime  @default(now())
  midp        Midp      @relation(fields: [midpId], references: [id], onDelete: Cascade)
}

model Tidp {
  id          String     @id @default(cuid())
  midpId      String
  projectId   String
  title       String
  discipline  String?
  responsible String?
  status      String     @default("DRAFT")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  midp        Midp       @relation(fields: [midpId], references: [id], onDelete: Cascade)
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items       TidpItem[]
}

model TidpItem {
  id        String    @id @default(cuid())
  tidpId    String
  title     String
  format    String?
  lodLevel  String?
  dueDate   DateTime?
  status    String    @default("PENDING")
  notes     String?
  createdAt DateTime  @default(now())
  tidp      Tidp      @relation(fields: [tidpId], references: [id], onDelete: Cascade)
}

model Eir {
  id           String       @id @default(cuid())
  projectId    String
  title        String
  version      String       @default("1.0")
  status       String       @default("DRAFT")
  purpose      String?
  scope        String?
  requirements String?
  deliverables String?
  standards    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sections     EirSection[]
}

model EirSection {
  id         String  @id @default(cuid())
  eirId      String
  sectionNo  String
  title      String
  content    String?
  status     String  @default("IN_PROGRESS")
  orderIndex Int     @default(0)
  eir        Eir     @relation(fields: [eirId], references: [id], onDelete: Cascade)
}

model Air {
  id           String       @id @default(cuid())
  projectId    String
  title        String
  version      String       @default("1.0")
  status       String       @default("DRAFT")
  assetType    String?
  requirements String?
  dataFields   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sections     AirSection[]
}

model AirSection {
  id         String  @id @default(cuid())
  airId      String
  sectionNo  String
  title      String
  content    String?
  status     String  @default("IN_PROGRESS")
  orderIndex Int     @default(0)
  air        Air     @relation(fields: [airId], references: [id], onDelete: Cascade)
}

model CdeDocument {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  docCode        String?
  revision       String   @default("P01")
  status         String   @default("WIP")
  discipline     String?
  fileType       String?
  fileSize       Int?
  url            String?
  fileUrl        String?
  fileName       String?
  fileMime       String?
  owner          String?
  access         String   @default("PRIVATE")
  approvalStatus String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LodSpec {
  id         String   @id @default(cuid())
  projectId  String
  element    String
  discipline String?
  lodLevel   String   @default("LOD 200")
  loaLevel   String?
  purpose    String?
  notes      String?
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ClashDetection {
  id               String    @id @default(cuid())
  projectId        String?
  title            String
  description      String?
  discipline1      String?
  discipline2      String?
  severity         String    @default("MEDIUM")
  status           String    @default("OPEN")
  assignedTo       String?
  detectedAt       DateTime  @default(now())
  resolvedAt       DateTime?
  notes            String?
  aiSeverity       String?
  aiCategory       String?
  aiRecommendation String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project?  @relation(fields: [projectId], references: [id])
}

model ResponsibilityMatrix {
  id          String   @id @default(cuid())
  projectId   String?
  discipline  String
  deliverable String
  role        String
  responsible String?
  accountable String?
  consulted   String?
  informed    String?
  notes       String?
  createdAt   DateTime @default(now())
  project     Project? @relation(fields: [projectId], references: [id])
}

model NamingConvention {
  id          String   @id @default(cuid())
  projectId   String?
  name        String
  pattern     String
  description String?
  fields      String?
  example     String?
  createdAt   DateTime @default(now())
  project     Project? @relation(fields: [projectId], references: [id])
}

model Meeting {
  id           String               @id @default(cuid())
  projectId    String?
  title        String
  description  String?
  scheduledAt  DateTime
  duration     Int                  @default(60)
  status       String               @default("SCHEDULED")
  location     String?
  isVirtual    Boolean              @default(true)
  roomId       String?
  recordingUrl String?
  agenda       String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  actionItems  ActionItem[]
  comments     Comment[]
  project      Project?             @relation(fields: [projectId], references: [id])
  minutes      MeetingMinute[]
  notes        MeetingNote[]
  participants MeetingParticipant[]
}

model MeetingParticipant {
  id        String  @id @default(cuid())
  meetingId String
  userId    String?
  name      String
  email     String?
  role      String  @default("ATTENDEE")
  attended  Boolean @default(false)
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User?   @relation(fields: [userId], references: [id])
}

model MeetingMinute {
  id         String   @id @default(cuid())
  meetingId  String
  section    String
  content    String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model ActionItem {
  id          String    @id @default(cuid())
  meetingId   String
  title       String
  description String?
  assigneeId  String?
  dueDate     DateTime?
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now())
  assignee    User?     @relation("ActionItemAssignee", fields: [assigneeId], references: [id])
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model Lead {
  id                  String   @id @default(cuid())
  company             String
  contactName         String
  contactEmail        String?
  contactPhone        String?
  country             String?
  source              String?
  serviceInterest     String?
  estValue            Float    @default(0)
  stage               String   @default("TO_CONTACT")
  probability         Int      @default(10)
  ownerName           String?
  notes               String?
  orderIndex          Int      @default(0)
  convertedToClientId String?
  aiScore             Int?
  aiScoreLabel        String?
  aiInsight           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  convertedClient     Client?  @relation(fields: [convertedToClientId], references: [id])
}

model Invoice {
  id          String            @id @default(cuid())
  invoiceNo   String            @unique
  clientId    String?
  projectId   String?
  amount      Float
  currency    String            @default("AED")
  status      String            @default("DRAFT")
  issueDate   DateTime          @default(now())
  dueDate     DateTime?
  paidDate    DateTime?
  description String?
  lineItems   String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  client      Client?           @relation(fields: [clientId], references: [id])
  project     Project?          @relation(fields: [projectId], references: [id])
  items       InvoiceLineItem[]
}

model Subcontractor {
  id             String                    @id @default(cuid())
  companyName    String
  specialization String?
  specialty      String?
  contactPerson  String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  country        String?
  rating         Float                     @default(0)
  status         String                    @default("ACTIVE")
  active         Boolean                   @default(true)
  notes          String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  assignments    SubcontractorAssignment[]
  members        SubcontractorMember[]
}

model SubcontractorMember {
  id              String        @id @default(cuid())
  subcontractorId String
  userId          String?
  name            String
  role            String?
  email           String?
  phone           String?
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id])
}

model SubcontractorAssignment {
  id               String        @id @default(cuid())
  subcontractorId  String
  projectId        String
  scope            String?
  startDate        DateTime?
  endDate          DateTime?
  status           String        @default("ACTIVE")
  performanceScore Float?
  notes            String?
  createdAt        DateTime      @default(now())
  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subcontractor    Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
}

model Risk {
  id          String    @id @default(cuid())
  projectId   String?
  title       String
  description String?
  category    String?
  probability String    @default("MEDIUM")
  impact      String    @default("MEDIUM")
  riskScore   Int       @default(0)
  status      String    @default("OPEN")
  mitigation  String?
  contingency String?
  owner       String?
  reviewDate  DateTime?
  trend       String?   @default("STABLE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project?  @relation(fields: [projectId], references: [id])
}

model WarRoomIncident {
  id          String    @id @default(cuid())
  title       String
  description String?
  severity    String    @default("MEDIUM")
  status      String    @default("OPEN")
  assigneeId  String?
  projectId   String?
  source      String?   @default("WAR_ROOM")
  resolution  String?
  reportedAt  DateTime  @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
}

model Lesson {
  id          String   @id @default(cuid())
  projectId   String?
  title       String
  description String?
  category    String?
  impact      String   @default("MEDIUM")
  action      String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
}

model Rfi {
  id          String    @id @default(cuid())
  projectId   String
  raisedById  String
  title       String
  description String?
  discipline  String?
  priority    String    @default("MEDIUM")
  status      String    @default("OPEN")
  response    String?
  dueDate     DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())

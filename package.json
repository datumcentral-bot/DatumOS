{
  "name": "datumos",
  "version": "1.0.0",
  "private": true,
  "description": "DatumOS — Custom ERP + Client Portal for Datum Studios Engineering Consultancy",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node server.js",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs && node prisma/seed-v11.mjs",
    "db:seed:v11": "node prisma/seed-v11.mjs",
    "setup": "prisma generate && prisma migrate dev --name init && node prisma/seed.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "next": "^14.2.33",
    "next-auth": "^4.24.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14"
  }
}
